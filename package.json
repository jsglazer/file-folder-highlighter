{
	"name": "dynamic-file-folder-highlighter",
	"version": "1.2.7",
	"description": "Custom colors for files/folders via right-click, YAML frontmatter rules, hierarchy, regex, and conditional highlighting.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc --noEmit -p tsconfig.json && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint src",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"keywords": [],
	"author": "Josh",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@eslint/json": "^0.14.0",
		"@types/node": "^22.0.0",
		"@vitest/coverage-v8": "^4.1.8",
		"esbuild": "0.17.3",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"obsidian": "latest",
		"prettier": "^3.8.4",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.61.0",
		"vitest": "^4.1.8"
	}
}
