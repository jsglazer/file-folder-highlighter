{
  "compilerOptions": {
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES6",
    "allowSyntheticDefaultImports": true,
    "importHelpers": true,
    "jsx": "react",
    "lib": [
      "ES6",
      "DOM"
    ],
    "moduleResolution": "bundler",
    "strict": true,
    "paths": {
      "obsidian": [
        "./node_modules/obsidian/obsidian.d.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ]
}
